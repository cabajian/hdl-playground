# Verible Lint Rules
# Documentation: https://chipsalliance.github.io/verible/lint.html

# Basic rules
line-length=length:100
no-trailing-spaces
no-tabs
package-filename
module-filename

# Naming styles
parameter-name-style=localparam_style:ALL_CAPS;parameter_style:ALL_CAPS
enum-name-style=style_regex:[a-z_0-9]+(_t|_e)

# Module specific
module-parameter
module-begin-block

# Storage types
explicit-parameter-storage-type

# Disable rules by prefixing with -
-enum-name-style
